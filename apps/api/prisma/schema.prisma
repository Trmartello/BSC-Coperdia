generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  CONTROLADORIA
  GESTOR
  DIRETORIA
}

enum IndicatorType {
  INPUT
  CALCULATED
}

enum MeasureUnit {
  CURRENCY
  PERCENTAGE
  NUMBER
  DAYS
  INDEX
}

enum Periodicity {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum IndicatorStatus {
  ON_TRACK
  AT_RISK
  OFF_TRACK
  NO_DATA
}

enum IndicatorDirection {
  HIGHER_IS_BETTER
  LOWER_IS_BETTER
}

enum ScenarioStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  SIMULATE
}

// ─── Plano de Ação enums ──────────────────────────────────────────────────────

enum PlanStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum InitiativeStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum ActionItemStatus {
  PENDING
  IN_PROGRESS
  DONE
  OVERDUE
  CANCELLED
}

enum ActionItemPriority {
  HIGH
  MEDIUM
  LOW
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(GESTOR)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  scenarios       Scenario[]
  forecastValues  ForecastValue[]
  auditLogs       AuditLog[]
  actionPlans     ActionPlan[]
  planComments    PlanComment[]
  planAttachments PlanAttachment[]
  planAuditLogs   PlanAuditLog[]
  initiatives     Initiative[]
  actionItems     ActionItem[]
  mapCategories   MapCategory[]
  indicatorMaps   IndicatorMap[]

  @@map("users")
}

// ─── Indicators ──────────────────────────────────────────────────────────────

model Indicator {
  id          String             @id @default(cuid())
  code        String             @unique
  name        String
  description String?
  category    String
  type        IndicatorType
  unit        MeasureUnit
  periodicity Periodicity
  responsible String?
  active      Boolean            @default(true)
  sortOrder   Int                @default(0)
  direction   IndicatorDirection @default(HIGHER_IS_BETTER)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  formula        Formula?
  realizedValues RealizedValue[]
  forecastValues ForecastValue[]
  goals          Goal[]
  parents        IndicatorRelation[] @relation("ChildRelations")
  children       IndicatorRelation[] @relation("ParentRelations")
  scenarioValues ScenarioValue[]
  actionPlans    ActionPlan[]
  mapEntries     IndicatorMapEntry[]

  @@map("indicators")
}

// ─── Action Plans (Planos de Ação) ───────────────────────────────────────────
// indicatorId = null → plano avulso
// indicatorId = id   → vinculado a indicador

model ActionPlan {
  id          String     @id @default(cuid())
  indicatorId String?
  problem     String     // "Problema a resolver"
  description String?
  status      PlanStatus @default(OPEN)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  userId      String

  indicator   Indicator?       @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id])
  initiatives Initiative[]
  comments    PlanComment[]
  attachments PlanAttachment[]
  auditLogs   PlanAuditLog[]

  @@index([indicatorId])
  @@index([userId])
  @@map("action_plans")
}

// ─── Initiatives (Iniciativas dentro do Plano) ────────────────────────────────

model Initiative {
  id           String           @id @default(cuid())
  actionPlanId String
  title        String
  description  String?
  status       InitiativeStatus @default(OPEN)
  sortOrder    Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  userId       String

  actionPlan ActionPlan   @relation(fields: [actionPlanId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id])
  actions    ActionItem[]

  @@index([actionPlanId])
  @@map("initiatives")
}

// ─── Action Items (Ações dentro de uma Iniciativa) ───────────────────────────

model ActionItem {
  id            String             @id @default(cuid())
  initiativeId  String
  title         String
  description   String?
  priority      ActionItemPriority @default(MEDIUM)
  status        ActionItemStatus   @default(PENDING)
  dueDate       DateTime?
  ownerName     String?            // responsável (nome livre)
  ownerId       String?            // responsável (usuário do sistema, opcional)
  progress      Int                @default(0) // 0–100
  observations  String?
  completedAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  userId        String

  initiative Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@index([initiativeId])
  @@map("action_items")
}

// ─── Plan Comments ────────────────────────────────────────────────────────────

model PlanComment {
  id           String   @id @default(cuid())
  actionPlanId String
  content      String
  progress     Int?     // progresso reportado junto ao comentário
  createdAt    DateTime @default(now())
  userId       String

  actionPlan ActionPlan @relation(fields: [actionPlanId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@index([actionPlanId])
  @@map("plan_comments")
}

// ─── Plan Attachments ─────────────────────────────────────────────────────────

model PlanAttachment {
  id           String   @id @default(cuid())
  actionPlanId String
  filename     String
  url          String
  size         Int      // bytes
  mimeType     String
  createdAt    DateTime @default(now())
  userId       String

  actionPlan ActionPlan @relation(fields: [actionPlanId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@index([actionPlanId])
  @@map("plan_attachments")
}

// ─── Plan Audit Log ───────────────────────────────────────────────────────────

model PlanAuditLog {
  id            String   @id @default(cuid())
  actionPlanId  String
  userId        String
  action        String   // "CREATE" | "UPDATE" | "STATUS_CHANGE" | "PROGRESS" | "COMMENT" | "ATTACHMENT"
  field         String?
  previousValue Json?
  newValue      Json?
  createdAt     DateTime @default(now())

  actionPlan ActionPlan @relation(fields: [actionPlanId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@index([actionPlanId])
  @@map("plan_audit_logs")
}

// ─── Formula ─────────────────────────────────────────────────────────────────

model Formula {
  id            String   @id @default(cuid())
  indicatorId   String   @unique
  expression    String
  variables     Json
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  indicator Indicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)

  @@map("formulas")
}

// ─── Tree Relations ───────────────────────────────────────────────────────────

model IndicatorRelation {
  id        String @id @default(cuid())
  parentId  String
  childId   String
  weight    Float  @default(1.0)
  sortOrder Int    @default(0)

  parent Indicator @relation("ParentRelations", fields: [parentId], references: [id], onDelete: Cascade)
  child  Indicator @relation("ChildRelations",  fields: [childId],  references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
  @@map("indicator_relations")
}

// ─── Realized Values ─────────────────────────────────────────────────────────

model RealizedValue {
  id          String   @id @default(cuid())
  indicatorId String
  period      DateTime
  value       Decimal  @db.Decimal(20, 6)
  createdAt   DateTime @default(now())

  indicator Indicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)

  @@unique([indicatorId, period])
  @@map("realized_values")
}

// ─── Forecast Values ─────────────────────────────────────────────────────────

model ForecastValue {
  id          String   @id @default(cuid())
  indicatorId String
  scenarioId  String?
  period      DateTime
  value       Decimal  @db.Decimal(20, 6)
  isManual    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String

  indicator Indicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  scenario  Scenario? @relation(fields: [scenarioId],  references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId],      references: [id])

  @@unique([indicatorId, scenarioId, period])
  @@map("forecast_values")
}

// ─── Goals ───────────────────────────────────────────────────────────────────

model Goal {
  id          String   @id @default(cuid())
  indicatorId String
  period      DateTime
  value       Decimal  @db.Decimal(20, 6)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  indicator Indicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)

  @@unique([indicatorId, period])
  @@map("goals")
}

// ─── Scenarios ───────────────────────────────────────────────────────────────

model Scenario {
  id          String         @id @default(cuid())
  name        String
  description String?
  status      ScenarioStatus @default(DRAFT)
  isBaseline  Boolean        @default(false)
  period      DateTime
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  userId      String

  user           User            @relation(fields: [userId], references: [id])
  forecastValues ForecastValue[]
  scenarioValues ScenarioValue[]

  @@map("scenarios")
}

// ─── Scenario Values ─────────────────────────────────────────────────────────

model ScenarioValue {
  id           String          @id @default(cuid())
  scenarioId   String
  indicatorId  String
  period       DateTime
  value        Decimal         @db.Decimal(20, 6)
  delta        Decimal         @db.Decimal(20, 6) @default(0)
  deltaPercent Decimal         @db.Decimal(10, 4) @default(0)
  status       IndicatorStatus @default(NO_DATA)
  computedAt   DateTime        @default(now())

  scenario  Scenario  @relation(fields: [scenarioId],  references: [id], onDelete: Cascade)
  indicator Indicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)

  @@unique([scenarioId, indicatorId, period])
  @@map("scenario_values")
}

// ─── Indicator Maps ───────────────────────────────────────────────────────────

model MapCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6366f1") // hex color for badge
  isDefault Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String

  user         User           @relation(fields: [userId], references: [id])
  indicatorMaps IndicatorMap[]

  @@map("map_categories")
}

model IndicatorMap {
  id          String   @id @default(cuid())
  name        String
  description String?
  categoryId  String
  flowData    Json?    // ReactFlow nodes + edges JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String

  category MapCategory       @relation(fields: [categoryId], references: [id])
  user     User              @relation(fields: [userId], references: [id])
  entries  IndicatorMapEntry[]

  @@map("indicator_maps")
}

model IndicatorMapEntry {
  id           String @id @default(cuid())
  mapId        String
  indicatorId  String
  positionX    Float  @default(0)
  positionY    Float  @default(0)

  map       IndicatorMap @relation(fields: [mapId], references: [id], onDelete: Cascade)
  indicator Indicator    @relation(fields: [indicatorId], references: [id], onDelete: Cascade)

  @@unique([mapId, indicatorId])
  @@map("indicator_map_entries")
}

// ─── System Audit Log ─────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(cuid())
  userId     String
  action     AuditAction
  entity     String
  entityId   String
  before     Json?
  after      Json?
  scenarioId String?
  createdAt  DateTime    @default(now())
  ipAddress  String?

  user User @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
